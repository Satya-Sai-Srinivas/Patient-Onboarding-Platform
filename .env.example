# =============================================================================
# Patient Onboarding — Environment Variables
# =============================================================================
# Copy this file to .env in the relevant directory and fill in real values.
# Each section maps to a specific app in the monorepo.
# NEVER commit .env files containing real secrets.
# =============================================================================


# ── Backend (backend/) ────────────────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=true
LOG_LEVEL=INFO

# PostgreSQL connection (individual fields — config.py builds the URL from these)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patient_onboarding
DB_USER=postgres
DB_PASSWORD=changeme

# Feature flags
ENABLE_REALTIME=true
ENABLE_WEBSOCKETS=true
ENABLE_EVENTS=true

# CORS (comma-separated origins for production; leave * only in local dev)
# CORS_ORIGINS=http://localhost:5173,http://localhost:8081


# ── Web app (apps/web/) ───────────────────────────────────────────────────────
# Create apps/web/.env from these values.

# Base URL for the FastAPI backend — must match PORT above
VITE_API_BASE=http://localhost:8000

# Set to "true" to bypass API calls and use in-memory mock data
VITE_USE_MOCK=false


# ── Mobile app (apps/mobile/) ────────────────────────────────────────────────
# Create apps/mobile/.env from these values.
# NOTE: The Expo prefix EXPO_PUBLIC_ is required for values exposed to the
#       React Native bundle.  The backend runs on port 8000, NOT 3000.

EXPO_PUBLIC_API_URL=http://localhost:8000/api
