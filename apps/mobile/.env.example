# =============================================================================
# apps/mobile — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# Variables must be prefixed with EXPO_PUBLIC_ to be bundled into the app.
# =============================================================================

# Full base URL of the FastAPI backend, including /api path segment.
# Backend runs on port 8000 by default.
EXPO_PUBLIC_API_URL=http://localhost:8000/api
