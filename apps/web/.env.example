# =============================================================================
# apps/web — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# Base URL of the FastAPI backend (no trailing slash)
VITE_API_BASE=http://localhost:8000

# Set to "true" to bypass all API calls and use in-memory mock data
VITE_USE_MOCK=false

# Clinician ID used by the clinician dashboard view.
# In production this would come from an auth session; for local dev set it here.
VITE_CLINICIAN_ID=1
