# =============================================================================
# backend/ — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# All keys map directly to fields in config.py (Settings class).
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=true
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# config.py builds the DATABASE_URL from these individual fields.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=patient_onboarding
DB_USER=postgres
DB_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space- or comma-separated list of allowed frontend origins.
# Cannot be "*" when CORS_CREDENTIALS=true (browsers reject it).
# Add your production domain here for deployment.
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8081","https://your-domain.com"]

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_REALTIME=true
ENABLE_WEBSOCKETS=true
ENABLE_EVENTS=true


# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=4f8a3b2e1...your...long...copied...string...here
